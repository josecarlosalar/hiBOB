# ========================
# Google Cloud Platform (Vertex AI)
# ========================
GCP_PROJECT_ID=mi-proyecto-gcp
GCP_LOCATION=europe-west1
# Region especifica para Gemini Live (recomendado us-central1 para modelos preview Live)
GCP_LIVE_LOCATION=europe-west1

# ========================
# Google AI Studio (Opcional - Alternativa a Vertex AI)
# Si se proporciona, el asistente usará AI Studio en lugar de Vertex AI.
# ========================
GEMINI_API_KEY=tu-clave-de-ai-studio
VERTEX_EXPRESS_API_KEY=tu-clave-si-aplica

# ========================
# Google GenAI SDK
# NOTA: Gemini 2.0 Flash se retira el 01/06/2026
# Usar gemini-2.5-flash como modelo principal
# ========================
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=8192
GEMINI_TEMPERATURE=1.0
GEMINI_LIVE_MODEL=gemini-live-2.5-flash-preview
GEMINI_LIVE_MINIMAL_CONFIG=false
GEMINI_LIVE_DISABLE_TOOLS=false
GEMINI_LIVE_DISABLE_SPEECH_CONFIG=false
GEMINI_LIVE_DISABLE_TRANSCRIPTIONS=false
GEMINI_LIVE_DEBUG_VERBOSE=false

# ========================
# Credenciales GCP (Local Development)
# Ruta al archivo JSON del Service Account si usas Vertex AI localmente.
# En Cloud Run se recomienda usar Workload Identity Federation (dejar en blanco).
# ========================
GOOGLE_APPLICATION_CREDENTIALS=./credentials/sa-key.json

# ========================
# Firebase / Firestore
# ========================
FIREBASE_PROJECT_ID=tu-proyecto-firebase

# ========================
# Brave Search (Búsqueda Web en tiempo real)
# Obtén tu clave en https://api.search.brave.com/app/dashboard
# ========================
BRAVE_SEARCH_API_KEY=tu-clave-de-brave

# ========================
# VirusTotal (Análisis de Malware/Phishing)
# Obtén tu clave en https://www.virustotal.com
# ========================
VIRUSTOTAL_API_KEY=tu-clave-de-virustotal

# ========================
# Servidor Backend
# ========================
PORT=3000
NODE_ENV=development
