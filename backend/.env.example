# ========================
# Google Cloud Platform
# ========================
GCP_PROJECT_ID=websites-technology
GCP_LOCATION=us-central1
# Region especifica para Gemini Live (recomendado us-central1 para modelos preview Live)
GCP_LIVE_LOCATION=us-central1

# ========================
# Google GenAI SDK (@google/genai con vertexai:true)
# Usa Application Default Credentials (ADC) — NO se necesita GEMINI_API_KEY
#   - Local: GOOGLE_APPLICATION_CREDENTIALS apuntando al Service Account JSON
#   - Cloud Run: Workload Identity Federation (sin credenciales extra)
# NOTA: Gemini 2.0 Flash se retira el 01/06/2026
# Usar gemini-2.5-flash como modelo principal
# ========================
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=8192
GEMINI_TEMPERATURE=1.0
GEMINI_LIVE_MODEL=gemini-live-2.5-flash-preview
GEMINI_LIVE_MINIMAL_CONFIG=false
GEMINI_LIVE_DISABLE_TOOLS=false
GEMINI_LIVE_DISABLE_SPEECH_CONFIG=false
GEMINI_LIVE_DISABLE_TRANSCRIPTIONS=false
GEMINI_LIVE_DEBUG_VERBOSE=false

# ========================
# Credenciales GCP
# Opcion A: Ruta al archivo JSON del Service Account (desarrollo local)
# Opcion B: En Cloud Run, dejar en blanco y usar Workload Identity Federation
# ========================
GOOGLE_APPLICATION_CREDENTIALS=./credentials/gemini-agent-sa-key.json

# ========================
# Firebase / Firestore
# ========================
FIREBASE_PROJECT_ID=websites-technology

# ========================
# Tavily (búsqueda web)
# Obtén tu clave en https://app.tavily.com
# ========================
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========================
# Server
# ========================
PORT=3000
NODE_ENV=development
